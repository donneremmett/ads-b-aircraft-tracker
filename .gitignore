# ===================================================================
# 1. PYTHON & FLASK SPECIFIC
# ===================================================================
# Keeps compiled Python code and virtual environments out of Git
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
instance/
.pytest_cache/

# ===================================================================
# 2. SECURITY & KEYS (CRITICAL)
# ===================================================================
# Keeps secret map tokens or API keys hidden
.env
.env.local
secrets.json
config.private.json

# ===================================================================
# 3. RADAR & FLIGHT DATA STORAGE
# ===================================================================
# Keeps massive aircraft history logs and local databases out of Git
*.db
*.sqlite
*.sqlite3
*.log
data/
history/

# ===================================================================
# 4. HARDWARE & OPERATING SYSTEM FILES
# ===================================================================
# Hidden files generated by Windows, Mac, or your Raspberry Pi OS
.DS_Store
Thumbs.db
desktop.ini
.bash_history